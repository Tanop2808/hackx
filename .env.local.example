# Environment Variables Setup

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/sehat-setu
# OR for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/sehat-setu?retryWrites=true&w=majority

# JWT Secret for Authentication (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-this-in-production-with-a-long-random-string

# Next.js Environment
NEXT_PUBLIC_API_URL=http://localhost:3000
